# Slack credentials — from api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Groq API key — from console.groq.com (free tier: 14,400 req/day)
GROQ_API_KEY=gsk_your-key-here

# Bot identity — shown in thread saves and startup logs
BOT_NAME=AnimeshAI
AUTHOR_SLACK_USER_ID=U0123456789
AUTHOR_NAME=Animesh

# Access control — comma-separated Slack channel IDs. Leave empty to allow all channels.
ALLOWED_CHANNEL_IDS=

# Comma-separated Slack user IDs who can use save commands
ALLOWED_SAVER_IDS=U0123456789

# Health check server port
PORT=3000

# Corporate proxy SSL bypass (set to 0 if behind a corporate proxy)
# NODE_TLS_REJECT_UNAUTHORIZED=0
